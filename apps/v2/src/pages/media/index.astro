---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getCanonicalUrl, getEntriesBySection } from "../../lib/content.mjs";
import MediaListItem from "../../components/MediaListItem.astro";

const entries = await getEntriesBySection("media");

const grouped = entries.reduce((acc, entry) => {
  const year = entry.date?.getFullYear?.() ?? "unknown";
  if (!acc[year]) acc[year] = [];
  acc[year].push(entry);
  return acc;
}, {});

const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Media I recommend" description="A stream of talks, videos, and other media worth your time." canonical={getCanonicalUrl("/media/")}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <header class="mb-8">
      <h1 class="text-5xl text-white m-0">Media I recommend</h1>
      <p class="max-w-2xl mt-4 text-text/75">A stream of talks, videos, and other media worth your time. Some entries have notes; some are just a strong recommendation.</p>
    </header>

    <div class="flex flex-col gap-10">
      {years.map((year) => (
        <section>
          <h2 class="text-xs font-mono text-text/30 uppercase tracking-[0.15em] mb-3">{year}</h2>
          <ul class="flex flex-col m-0 p-0 list-none">
            {grouped[year].map((entry) => <MediaListItem entry={entry} />)}
          </ul>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
