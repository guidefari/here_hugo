---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getAllTags, getCanonicalUrl, getEntriesByTag } from "../../../lib/content.mjs";
import PostListItem from "../../../components/PostListItem.astro";

export async function getStaticPaths() {
  return (await getAllTags()).map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const entries = await getEntriesByTag(tag.slug);
---

<BaseLayout title={`#${tag.label}`} canonical={getCanonicalUrl(`/tags/${tag.slug}/`)}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <h1 class="mb-8 text-2xl font-bold tracking-tight text-white">#{tag.label}</h1>
    <ul class="posts article-list">
      {entries.map((entry) => <PostListItem entry={entry} />)}
    </ul>
    <section>
      <h2 class="text-xl"><a href="/tags/">All tags</a></h2>
    </section>
  </main>
</BaseLayout>
