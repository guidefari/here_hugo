---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getAllTags, getCanonicalUrl, getEntriesByTag } from "../../../lib/content.mjs";
import SectionMoreLink from "../../../components/SectionMoreLink.astro";
import YearGroupedList from "../../../components/YearGroupedList.astro";

export async function getStaticPaths() {
  return (await getAllTags()).map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const entries = await getEntriesByTag(tag.slug);
---

<BaseLayout title={`#${tag.label}`} canonical={getCanonicalUrl(`/tags/${tag.slug}/`)}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <header class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-5xl text-white m-0">#{tag.label}</h1>
        <p class="mt-3 mb-0 text-sm font-mono text-text/50">{entries.length} {entries.length === 1 ? "post" : "posts"}</p>
      </div>
      <SectionMoreLink href="/tags/" label="all tags" />
    </header>

    <YearGroupedList entries={entries} listId={`tag-${tag.slug}-list`} showSection={true} />
  </main>
</BaseLayout>
