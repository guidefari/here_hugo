---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import HomeIndex from "../components/HomeIndex.astro";
import { getCanonicalUrl } from "../lib/content.mjs";
import { site } from "../lib/site.mjs";
---

<BaseLayout title={site.title} description={site.subtitle} canonical={getCanonicalUrl("/")}>
  <main class="flex flex-col w-full px-4 lg:px-6 pb-16 max-w-7xl">
    <div class="mb-6 max-w-xl lg:hidden">
      <Hero />
    </div>
    <HomeIndex />
  </main>
</BaseLayout>
