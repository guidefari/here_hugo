---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import HomeWriting from "../components/HomeWriting.astro";
import HomeMedia from "../components/HomeMedia.astro";
import HomeProjects from "../components/HomeProjects.astro";
import { getCanonicalUrl } from "../lib/content.mjs";
import { site } from "../lib/site.mjs";
---

<BaseLayout title={site.title} description={site.subtitle} canonical={getCanonicalUrl("/")}>
  <main class="flex flex-col w-full px-4 lg:px-6 max-w-7xl">
    <div class="mb-6 max-w-xl lg:hidden">
      <Hero />
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,5fr)_minmax(0,3fr)] gap-10 xl:gap-14 items-start">
      <HomeWriting />
      <div class="flex flex-col gap-10 min-w-0">
        <HomeProjects />
        <HomeMedia />
      </div>
    </div>
  </main>
</BaseLayout>
