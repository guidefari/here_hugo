---
import { getNestedEntries } from "../../../lib/content.mjs";
import DefaultSingle from "../../../components/DefaultSingle.astro";

export async function getStaticPaths() {
  return (await getNestedEntries("read")).map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<DefaultSingle entry={entry} />
