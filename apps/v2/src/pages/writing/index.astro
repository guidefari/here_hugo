---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllEntries, getCanonicalUrl } from "../../lib/content.mjs";
import { writingSections } from "../../lib/site.mjs";
import YearGroupedList from "../../components/YearGroupedList.astro";

const entries = (await getAllEntries()).filter((entry) => writingSections.includes(entry.section));
---

<BaseLayout title="Writing" description="Notes, book reviews, TILs, and everything in between." canonical={getCanonicalUrl("/writing/")}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <header class="mb-8">
      <h1 class="text-5xl text-white m-0">Writing</h1>
      <p class="max-w-2xl mt-4 text-text/75">Notes, book reviews, TILs, and everything in between. Browse by section in the side nav.</p>
    </header>

    <YearGroupedList entries={entries} listId="writing-list" showSection={true} />
  </main>
</BaseLayout>
