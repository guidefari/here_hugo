---
import { getAliasTargets } from "../lib/content.mjs";
import AliasPage from "../components/AliasPage.astro";

export async function getStaticPaths() {
  return (await getAliasTargets()).map(({ alias, target }) => ({
    params: { alias: alias.replace(/^\/+|\/+$/g, "") },
    props: { target },
  }));
}

const { target } = Astro.props;
---

<AliasPage target={target} />
