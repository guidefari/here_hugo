---
import BaseLayout from "../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { getCanonicalUrl, getOgImage } from "../lib/content.mjs";

const { entry } = Astro.props;
const { Content } = await render(entry._entry);
const data = entry.data ?? {};
const goodFor = Array.isArray(data.good_for) ? data.good_for : [];
const notFor = Array.isArray(data.not_for) ? data.not_for : [];
const notes = Array.isArray(data.notes) ? data.notes : [];
const webring = Array.isArray(data.webring) ? data.webring : [];
const cta = data.cta ?? {};
const ringNav = webring.slice(0, 4);
const joinLink = webring[4];
---

<BaseLayout title={entry.title} description={entry.description} image={getOgImage(entry)} canonical={getCanonicalUrl(entry.permalink)}>
  <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
    <header class="mb-10 lg:grid lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-8 lg:items-start">
      <div>
        <h1 class="text-xs uppercase tracking-[0.24em] text-accentText">Unoffice Hours</h1>
        {entry.hasBody && (
          <div class="uh-intro mt-4 max-w-2xl text-base leading-relaxed text-[#D7DDD4] [&_a]:text-highlight [&_a]:no-underline hover:[&_a]:underline">
            <Content />
          </div>
        )}
      </div>
      {cta.url && (
        <a href={cta.url} class="uh-cta group mt-6 lg:mt-0">
          <div>
            <p class="uh-cta-eyebrow">Open calendar</p>
            <p class="uh-cta-title">{cta.label}</p>
          </div>
          <span class="uh-cta-arrow" aria-hidden="true">→</span>
        </a>
      )}
    </header>

    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-8">
      <main>
        <section class="mb-10">
          <h2 class="uh-section-title">What it's good for</h2>
          <ul class="mt-5 space-y-2.5">
            {goodFor.map((item) => <li class="uh-bullet">{item}</li>)}
          </ul>
        </section>

        <section>
          <h2 class="uh-section-title">What it isn't</h2>
          <ul class="mt-5 space-y-2.5">
            {notFor.map((item) => <li class="uh-bullet">{item}</li>)}
          </ul>
        </section>
      </main>

      <aside class="mt-10 space-y-6 lg:mt-0">
        {webring.length > 0 && (
          <div class="uh-card">
            <p class="text-xs uppercase tracking-[0.24em] text-accentText">Webring</p>
            <p class="mt-3 text-sm leading-relaxed text-[#D7DDD4]">This page is part of the <a href="https://unofficehours.com" class="highlighted-link">Unoffice Hours webring</a>.</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {ringNav.map((link) => (
                <a href={link.url} class="uh-chip">{link.label}</a>
              ))}
            </div>
            {joinLink && (
              <a href={joinLink.url} class="mt-5 inline-flex items-center gap-1 text-xs font-semibold text-highlight transition hover:underline">
                {joinLink.label} <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        )}

        {notes.length > 0 && (
          <div class="uh-card">
            <p class="text-xs uppercase tracking-[0.24em] text-accentText">Notes</p>
            <ul class="mt-3 space-y-2 text-sm text-[#D7DDD4]">
              {notes.map((note) => <li class="uh-bullet">{note}</li>)}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .uh-section-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #F5D547;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(245, 213, 71, 0.2);
  }

  .uh-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0F1F26;
    padding: 1.25rem;
  }

  .uh-bullet {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #D7DDD4;
  }

  .uh-bullet::before {
    content: "›";
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.25);
    font-weight: bold;
  }

  .uh-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid #F5D547;
    background: rgba(245, 213, 71, 0.06);
    padding: 1.25rem 1.5rem;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    color: #F5D547;
  }

  .uh-cta:hover {
    background: #F5D547;
    color: #000;
  }

  .uh-cta-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: inherit;
    opacity: 0.7;
  }

  .uh-cta-title {
    margin-top: 0.4rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: inherit;
    line-height: 1.3;
  }

  .uh-cta-arrow {
    font-size: 1.5rem;
    transition: transform 0.15s;
  }

  .uh-cta:hover .uh-cta-arrow {
    transform: translateX(4px);
  }

  .uh-chip {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.4rem 0.7rem;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .uh-chip:hover {
    color: #F5D547;
    border-color: #F5D547;
  }
</style>
