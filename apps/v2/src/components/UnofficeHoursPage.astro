---
import BaseLayout from "../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { getCanonicalUrl, getOgImage } from "../lib/content.mjs";

const { entry } = Astro.props;
const { Content } = await render(entry._entry);
const data = entry.data ?? {};
const goodFor = Array.isArray(data.good_for) ? data.good_for : [];
const notFor = Array.isArray(data.not_for) ? data.not_for : [];
const notes = Array.isArray(data.notes) ? data.notes : [];
const webring = data.webring ?? {};
const cta = data.cta ?? {};
---

<BaseLayout title={entry.title} description={entry.description} image={getOgImage(entry)} canonical={getCanonicalUrl(entry.permalink)}>
  <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
    <header class="mb-10 lg:grid lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-8 lg:items-start">
      <div>
        <h1 class="text-xs tracking-[0.24em] text-accentText">Unoffice Hours</h1>
        {entry.hasBody && (
          <div class="uh-intro mt-4 max-w-2xl text-base leading-relaxed text-[#D7DDD4] [&_a]:text-highlight [&_a]:no-underline hover:[&_a]:underline">
            <Content />
          </div>
        )}
      </div>
      {cta.url && (
        <a href={cta.url} class="uh-cta group mt-6 lg:mt-0">
          <div>
            <p class="uh-cta-eyebrow">Open calendar</p>
            <p class="uh-cta-title">{cta.label}</p>
          </div>
          <span class="uh-cta-arrow" aria-hidden="true">→</span>
        </a>
      )}
    </header>

    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-8">
      <main>
        <section class="mb-10">
          <h2 class="uh-section-title">What it's good for</h2>
          <ul class="mt-5 space-y-2.5">
            {goodFor.map((item) => <li class="uh-bullet">{item}</li>)}
          </ul>
        </section>

        <section>
          <h2 class="uh-section-title">What it isn't</h2>
          <ul class="mt-5 space-y-2.5">
            {notFor.map((item) => <li class="uh-bullet">{item}</li>)}
          </ul>
        </section>
      </main>

      <aside class="mt-10 space-y-6 lg:mt-0">
        {(webring.previous || webring.next) && (
          <div class="uh-card">
            <p class="text-xs tracking-[0.24em] text-accentText">Webring</p>
            <p class="mt-3 text-sm leading-relaxed text-[#D7DDD4]">This page is part of the <a href="https://unofficehours.com" class="highlighted-link">Unoffice Hours webring</a>.</p>

            <div class="mt-5 grid grid-cols-2 gap-2">
              {webring.previous && (
                <a href={webring.previous.url} class="uh-webring-nav uh-webring-prev">
                  <span class="uh-webring-arrow" aria-hidden="true">←</span>
                  <span>{webring.previous.label}</span>
                </a>
              )}
              {webring.next && (
                <a href={webring.next.url} class="uh-webring-nav uh-webring-next">
                  <span>{webring.next.label}</span>
                  <span class="uh-webring-arrow" aria-hidden="true">→</span>
                </a>
              )}
            </div>

            {(webring.random || webring.all_sites) && (
              <div class="mt-3 flex items-center gap-3 text-xs">
                {webring.random && <a href={webring.random.url} class="uh-webring-secondary">{webring.random.label}</a>}
                {webring.random && webring.all_sites && <span class="text-accentText/30">·</span>}
                {webring.all_sites && <a href={webring.all_sites.url} class="uh-webring-secondary">{webring.all_sites.label}</a>}
              </div>
            )}

            {webring.join && (
              <a href={webring.join.url} class="mt-5 inline-flex items-center gap-1 text-xs font-semibold text-highlight transition hover:underline">
                {webring.join.label} <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        )}

        {notes.length > 0 && (
          <div class="uh-card">
            <p class="text-xs tracking-[0.24em] text-accentText">Notes</p>
            <ul class="mt-3 space-y-2 text-sm text-[#D7DDD4]">
              {notes.map((note) => <li class="uh-bullet">{note}</li>)}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .uh-section-title {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    color: #F5D547;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(245, 213, 71, 0.2);
  }

  .uh-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0F1F26;
    padding: 1.25rem;
  }

  .uh-bullet {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #D7DDD4;
  }

  .uh-bullet::before {
    content: "›";
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.25);
    font-weight: bold;
  }

  .uh-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid #F5D547;
    background: rgba(245, 213, 71, 0.06);
    padding: 1.25rem 1.5rem;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    color: #F5D547;
  }

  .uh-cta:hover {
    background: #F5D547;
    color: #000;
  }

  .uh-cta-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    color: inherit;
    opacity: 0.7;
  }

  .uh-cta-title {
    margin-top: 0.4rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: inherit;
    line-height: 1.3;
  }

  .uh-cta-arrow {
    font-size: 1.5rem;
    transition: transform 0.15s;
  }

  .uh-cta:hover .uh-cta-arrow {
    transform: translateX(4px);
  }

  .uh-webring-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.75rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    min-height: 2.75rem;
  }

  .uh-webring-nav:hover {
    border-color: #F5D547;
    color: #F5D547;
  }

  .uh-webring-prev {
    justify-content: flex-start;
  }

  .uh-webring-next {
    justify-content: space-between;
  }

  .uh-webring-arrow {
    font-size: 0.95rem;
    opacity: 0.65;
  }

  .uh-webring-nav:hover .uh-webring-arrow {
    opacity: 1;
  }

  .uh-webring-secondary {
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 500;
    transition: color 0.15s;
  }

  .uh-webring-secondary:hover {
    color: #F5D547;
  }
</style>
