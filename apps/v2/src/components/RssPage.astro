---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllTags, getCanonicalUrl } from "../lib/content.mjs";

const tags = getAllTags();
---

<BaseLayout title="RSS Feeds" canonical={getCanonicalUrl("/rss/")}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <h1>RSS Feeds</h1>
    <ul class="mb-10">
      <li><a href="/index.xml">All Content</a></li>
      <li><a href="/note/index.xml">Notes</a></li>
      <li><a href="/podcast/index.xml">Podcast Notes</a></li>
      <li><a href="/book/index.xml">Book Notes</a></li>
      <li><a href="/media/index.xml">Recommended media</a></li>
      <li><a href="/resource/index.xml">General resources</a></li>
    </ul>

    <h2>Tag-specific feeds:</h2>
    <ul class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
      {tags.map((tag) => <li><a href={`/tags/${tag.slug}/index.xml`}>{tag.label}</a></li>)}
    </ul>
  </main>
</BaseLayout>
