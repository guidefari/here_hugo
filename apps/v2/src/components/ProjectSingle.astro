---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCanonicalUrl } from "../lib/content.mjs";

const { project } = Astro.props;

const kindIcons = {
  video: "▶",
  docs: "◈",
  article: "✎",
};
---

<BaseLayout
  title={`${project.title}`}
  description={project.description}
  canonical={getCanonicalUrl(`/projects/${project.slug}/`)}
>
  <main class="flex flex-col mx-auto w-full max-w-3xl px-4 lg:px-6 py-8">
    <div class="mb-6">
      <a href="/" class="text-xs text-text/40 hover:text-highlight transition-colors">&larr; home</a>
    </div>

    <div class="mb-8">
      <h1 class="text-4xl font-bold text-white m-0 mb-2">{project.title}</h1>
      <p class="text-base text-text/60 m-0">{project.description}</p>

      <div class="flex items-center gap-3 mt-4">
        <a
          href={project.github}
          class="inline-flex items-center gap-1.5 text-xs text-text/50 hover:text-highlight transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          source
        </a>
        {project.website && (
          <a
            href={project.website}
            class="inline-flex items-center gap-1.5 text-xs text-text/50 hover:text-highlight transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            site
          </a>
        )}
      </div>
    </div>

    {project.topics.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {project.topics.map((topic) => (
          <span class="text-[10px] font-mono uppercase tracking-wider text-highlight/70 bg-highlight/10 px-2 py-0.5 rounded-sm">
            {topic}
          </span>
        ))}
      </div>
    )}

    {project.motivation && (
      <section class="mb-10">
        <h2 class="text-lg font-bold text-white m-0 mb-3">Why this project</h2>
        <p class="text-sm text-text/70 leading-relaxed m-0">{project.motivation}</p>
      </section>
    )}

    {project.links.length > 0 && (
      <section>
        <h2 class="text-lg font-bold text-white m-0 mb-3">Related</h2>
        <ul class="flex flex-col gap-2 m-0 p-0">
          {project.links.map((link) => (
            <li class="list-none">
              <a
                href={link.url}
                class="flex items-center gap-2.5 p-3 border border-text/10 rounded-sm bg-text/[0.03] hover:border-highlight/30 hover:bg-highlight/[0.04] transition-colors group"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="text-xs text-text/30 group-hover:text-highlight/50 w-4 text-center shrink-0">
                  {kindIcons[link.kind] ?? "·"}
                </span>
                <span class="text-sm text-text/70 group-hover:text-highlight transition-colors">
                  {link.label}
                </span>
                <span class="text-[10px] font-mono text-text/25 ml-auto uppercase">{link.kind}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>
</BaseLayout>
