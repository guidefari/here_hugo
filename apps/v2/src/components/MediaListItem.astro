---
import { formatDate } from "../lib/content.mjs";

const { entry } = Astro.props;
const mediaType = entry.data.media_type;
const youtubeId = entry.data.youtube_id;
const image = entry.images[0];
---

<li class="list-none">
  <a href={entry.permalink} class="group flex items-start gap-4 py-3 -mx-2 px-2 no-underline rounded-sm hover:bg-text/[0.04] transition-colors">
    <div class="w-32 shrink-0 aspect-video overflow-hidden rounded-sm bg-black">
      {mediaType === "youtube" && youtubeId ? (
        <img src={`https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`} alt={entry.title} class="w-full h-full object-cover" loading="lazy" />
      ) : image ? (
        <img src={image} alt={entry.title} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
          <span class="text-text/20 text-2xl font-mono">{mediaType === "podcast" ? "◎" : mediaType === "article" ? "≡" : mediaType === "link" ? "↗" : "▶"}</span>
        </div>
      )}
    </div>

    <div class="flex flex-col min-w-0 gap-1">
      <span class="text-base font-medium leading-snug text-text/90 group-hover:text-highlight transition-colors line-clamp-2">{entry.title}</span>
      <span class="text-xs text-accentText/60">
        <time>{formatDate(entry.date, { month: "short", year: "2-digit" })}</time>
        {entry.data.creator && <span> · {entry.data.creator}</span>}
        {entry.hasBody && <span class="ml-2 text-highlight/60">has notes</span>}
      </span>
    </div>
  </a>
</li>
