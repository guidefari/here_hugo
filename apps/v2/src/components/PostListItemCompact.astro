---
import { sectionLinks } from "../lib/site.mjs";

const { entry } = Astro.props;
const sectionHref = sectionLinks[entry.section] ?? `/${entry.section}/`;
---

<li class="list-none py-2" data-section={entry.section}>
  <div class="flex items-start gap-3">
    <a href={sectionHref} class="w-16 shrink-0 text-xs font-mono text-accentText/60 lowercase hover:text-accentText transition-colors no-underline">{entry.section}</a>
    <a href={entry.permalink} class="post-link text-sm font-bold leading-snug text-highlight hover:text-white transition-colors duration-150 no-underline">{entry.title}</a>
  </div>
</li>
