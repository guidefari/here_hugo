---
import { formatDate } from "../lib/content.mjs";
import { sectionLinks } from "../lib/site.mjs";

const { entry, dateOptions = { month: "short", day: "numeric" } } = Astro.props;
const sectionHref = sectionLinks[entry.section] ?? `/${entry.section}/`;
---

<li class="list-none py-3.5" data-section={entry.section}>
  <div class="flex flex-col gap-1">
    <a href={entry.permalink} class="post-link text-base lg:text-lg font-bold leading-snug text-highlight hover:text-white transition-colors duration-150 no-underline">{entry.title}</a>
    {entry.description && (
      <span class="text-sm text-text/55 leading-snug line-clamp-2">{entry.description}</span>
    )}
    <span class="flex items-center gap-2 text-xs font-mono lowercase">
      <a href={sectionHref} class="text-accentText/60 hover:text-accentText transition-colors no-underline">{entry.section}</a>
      {entry.date && (
        <>
          <span class="text-text/25">&middot;</span>
          <time class="text-text/40" datetime={entry.date.toISOString()}>{formatDate(entry.date, dateOptions)}</time>
        </>
      )}
    </span>
  </div>
</li>
