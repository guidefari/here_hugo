---
---

<dialog id="search-modal" aria-label="Search" class="search-modal">
  <div id="pagefind-ui-root" data-pagefind-ui></div>
  <noscript>
    <p class="p-4 text-sm">JavaScript is required for search.</p>
  </noscript>
</dialog>

<style>
  .search-modal {
    padding: 0;
    border: none;
    background: transparent;
    color-scheme: light dark;
    max-width: 720px;
    width: min(90vw, 720px);
    margin: 6vh auto;
    overflow: visible;
  }
  .search-modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }
  #pagefind-ui-root {
    min-height: 4rem;
  }
</style>

<script>
  const dialogId = "search-modal";
  const rootId = "pagefind-ui-root";
  const pagefindCss = "/pagefind/pagefind-ui.css";
  const pagefindJs = "/pagefind/pagefind-ui.js";

  function init() {
    const dialog = document.getElementById(dialogId);
    const root = document.getElementById(rootId);
    if (!dialog || !root) return;

    let pagefindUI = null;
    let initializing = null;

    function ensurePagefind() {
      if (pagefindUI) return pagefindUI;
      if (initializing) return initializing;
      initializing = (async () => {
        try {
          if (!document.querySelector(`link[href$="${pagefindCss}"]`)) {
            const link = document.createElement("link");
            link.rel = "stylesheet";
            link.href = pagefindCss;
            document.head.appendChild(link);
          }
          if (!window.PagefindUI) {
            await import(/* @vite-ignore */ pagefindJs);
          }
          pagefindUI = new window.PagefindUI({
            element: root,
            showImages: false,
            showSubResults: true,
            resetStyles: true,
          });
        } catch (error) {
          console.error("Pagefind UI failed to load", error);
          if (root) {
            root.innerHTML =
              '<p style="padding: 1rem; color: #888; font-size: 0.875rem;">Search is not available in dev mode. Run <code>bun build</code> and serve <code>apps/v2/dist</code> to use search.</p>';
          }
        }
        return pagefindUI;
      })();
      return initializing;
    }

    function open() {
      if (typeof dialog.showModal === "function") dialog.showModal();
      ensurePagefind();
    }

    function close() {
      if (dialog.open) dialog.close();
    }

    document.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        if (dialog.open) close();
        else open();
        return;
      }
      if (event.key === "Escape" && dialog.open) {
        close();
      }
    });

    document.addEventListener("click", (event) => {
      const trigger = event.target instanceof Element
        ? event.target.closest("[data-search-toggle]")
        : null;
      if (trigger) {
        event.preventDefault();
        open();
        return;
      }
      if (event.target === dialog) close();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
