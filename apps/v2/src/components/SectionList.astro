---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCanonicalUrl, getEntriesBySection, getSectionInfo } from "../lib/content.mjs";
import PostListItem from "./PostListItem.astro";
import WritingList from "./WritingList.astro";

const { section } = Astro.props;
const info = await getSectionInfo(section);
const entries = await getEntriesBySection(section);
const path = `/${section}/`;
---

<BaseLayout title={info.title} description={info.description} canonical={getCanonicalUrl(path)}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <div class="mb-8">
      <h1 class="text-5xl text-white m-0">{info.title}</h1>
      {info.description && <p class="max-w-2xl mt-4 text-text/75">{info.description}</p>}
    </div>

    <WritingList listId={`section-${section}-list`}>
      {entries.map((entry) => <PostListItem entry={entry} showSection={false} />)}
    </WritingList>
  </main>
</BaseLayout>
