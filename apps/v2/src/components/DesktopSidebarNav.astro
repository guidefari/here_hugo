---
import { navItems } from "../lib/site.mjs";

const { isHome = false } = Astro.props;
---

<nav aria-label="Site sections" class="w-full flex flex-col justify-between h-full">
  <div>
    {isHome ? (
      <div class="flex flex-col items-center text-center mb-4">
        <img class="w-24 h-24 rounded-full ring-2 ring-highlight/20 mb-3" style="view-transition-name: hero-avatar;" src="https://res.cloudinary.com/hokaspokas/image/upload/v1661928720/bar_shpohc.png" alt="Guide writing software in a bar" />
        <h1 class="text-lg font-bold text-white m-0 leading-tight" style="view-transition-name: hero-name;">
          <span class="relative inline-block before:absolute before:-inset-1 before:block before:-skew-y-3 before:bg-black">
            <span class="relative text-white skew-y-3">Guide Fari</span>
          </span>
        </h1>
        <div class="flex items-center gap-2 text-xs font-mono mt-1">
          <span class="text-text/60">Software Engineer</span>
          <span class="text-text/30">&middot;</span>
          <a class="text-highlight hover:text-white transition-colors" href="http://goosebumps.fm">Music Curator</a>
        </div>
        <p class="mt-3 text-xs leading-relaxed text-text/60 border-l-2 border-highlight/40 pl-3 text-left">Writing down lessons and observations along the way.</p>
      </div>
    ) : (
      <div class="flex items-center gap-3 mb-4">
        <img class="w-10 h-10 rounded-full ring-2 ring-highlight/20" style="view-transition-name: hero-avatar;" src="https://res.cloudinary.com/hokaspokas/image/upload/v1661928720/bar_shpohc.png" alt="Guide writing software in a bar" />
        <div class="flex flex-col">
          <span class="text-sm font-bold text-white leading-tight" style="view-transition-name: hero-name;">Guide Fari</span>
          <span class="text-xs font-mono text-text/50">Software Engineer</span>
        </div>
      </div>
    )}

    <ul class="flex flex-col gap-1 p-0 m-0 list-none">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="nav-chip w-full justify-start" data-nav-sound>
            <span class="nav-chip__bracket">[</span><span class="nav-chip__label">{item.label}</span><span class="nav-chip__bracket">]</span>
          </a>
        </li>
      ))}
      <li>
        <button type="button" data-search-toggle class="nav-chip w-full justify-start" data-nav-sound aria-label="Search (Cmd+K)">
          <span class="nav-chip__bracket">[</span>
          <span class="nav-chip__label flex-1 text-left">search</span>
          <kbd class="hidden xl:inline-block ml-auto text-[10px] font-mono text-text/50 border border-text/30 px-1 rounded-sm">⌘K</kbd>
          <span class="nav-chip__bracket">]</span>
        </button>
      </li>
    </ul>
  </div>

  <div class="mt-6 pt-4 border-t border-text/20">
    <p class="mt-0 mb-3 text-sm text-text/75">Notes + reading list in your inbox.</p>
    <form action="https://buttondown.email/api/emails/embed-subscribe/guidefari" method="post" target="popupwindow" class="flex flex-col gap-2">
      <label for="bd-email-nav" class="sr-only">Email address</label>
      <input type="email" name="email" id="bd-email-nav" required placeholder="you@domain.com" autocomplete="email" class="w-full px-3 py-2 font-mono text-sm bg-transparent border rounded-sm border-text/40 text-text placeholder:text-text/40 focus:outline-none focus:border-highlight focus:ring-1 focus:ring-highlight" />
      <button type="submit" class="px-4 py-2 font-mono text-sm font-semibold tracking-wide uppercase transition border rounded-sm border-highlight bg-highlight text-black hover:bg-transparent hover:text-highlight focus:outline-none focus:ring-2 focus:ring-highlight">Subscribe</button>
    </form>
  </div>
</nav>
