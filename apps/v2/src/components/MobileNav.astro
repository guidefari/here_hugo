---
import { navItems, writingTree } from "../lib/site.mjs";

const currentPath = Astro.url.pathname;
const isWritingArea = writingTree.children.some(
  (child) => currentPath === child.href || currentPath.startsWith(child.href)
);
const writingChildHrefs = new Set(writingTree.children.map((c) => c.href));
---

<button id="mobile-nav-open" aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-nav-overlay" class="lg:hidden fixed top-4 right-4 z-50 flex flex-col justify-center items-center w-10 h-10 gap-1.5 border border-text/40 rounded-sm bg-bg transition hover:border-highlight focus:outline-none focus:ring-2 focus:ring-highlight" data-nav-sound>
  <span class="hamburger-bar block w-5 h-px bg-text transition-all duration-300"></span>
  <span class="hamburger-bar block w-5 h-px bg-text transition-all duration-300"></span>
  <span class="hamburger-bar block w-5 h-px bg-text transition-all duration-300"></span>
</button>

<div id="mobile-nav-overlay" role="dialog" aria-modal="true" aria-label="Site navigation" class="mobile-nav lg:hidden fixed inset-0 z-40 flex flex-col bg-bg overflow-y-auto transition-[transform,opacity] duration-300 ease-out">
  <div class="flex items-center justify-between px-5 py-3 border-b border-text/20 shrink-0">
    <div class="flex flex-col">
      <span class="font-mono text-base font-bold text-text">
        <span class="relative inline-block ml-1 before:absolute before:-inset-1 before:block before:-skew-y-3 before:bg-black">
          <span class="relative text-white skew-y-3">Guide Fari</span>
        </span>
      </span>
      <span class="font-mono text-xs text-text/60 mt-1">Software Engineer &middot; <a href="http://goosebumps.fm" class="text-highlight hover:underline">Music Curator</a></span>
    </div>
    <button id="mobile-nav-close" aria-label="Close navigation" class="flex items-center justify-center w-9 h-9 border border-text/30 rounded-sm font-mono text-xs text-text/70 hover:border-highlight hover:text-highlight transition focus:outline-none focus:ring-2 focus:ring-highlight" data-nav-sound>[×]</button>
  </div>

  <nav aria-label="Site sections" class="px-5 py-4">
    <ul class="flex flex-col gap-1.5 p-0 m-0 list-none">
      {navItems.map((item) => {
        if (item.label === "writing") {
          return (
            <li class="nav-tree" data-tree="writing">
              <details open={isWritingArea} class="group">
                <summary
                  class:list={["nav-chip w-full justify-start text-left cursor-pointer list-none", isWritingArea && "border-highlight text-highlight"]}
                  data-nav-sound
                >
                  <span class="nav-chip__bracket">[</span>
                  <span class="nav-chip__label flex-1">{item.label}</span>
                  <span class="nav-chip__bracket">]</span>
                  <span class="nav-tree__caret text-text/50 text-[10px] transition-transform group-open:rotate-90" aria-hidden="true">▸</span>
                </summary>
                <ul class="nav-tree__children flex flex-col gap-1 mt-1.5 pl-3 border-l border-text/15">
                  {writingTree.children.map((child) => {
                    const isActive = currentPath === child.href;
                    return (
                      <li>
                        <a
                          href={child.href}
                          class:list={["nav-chip nav-chip--child w-full justify-start text-[0.72rem]", isActive && "border-highlight text-highlight"]}
                          aria-current={isActive ? "page" : undefined}
                          data-nav-sound
                        >
                          <span class="nav-chip__bracket">[</span>
                          <span class="nav-chip__label">{child.label}</span>
                          <span class="nav-chip__bracket">]</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </details>
            </li>
          );
        }
        const isActive = writingChildHrefs.has(item.href) && currentPath === item.href;
        return (
          <li>
            <a
              href={item.href}
              class:list={["nav-chip w-full justify-start", isActive && "border-highlight text-highlight"]}
              aria-current={isActive ? "page" : undefined}
              data-nav-sound
            >
              <span class="nav-chip__bracket">[</span><span class="nav-chip__label">{item.label}</span><span class="nav-chip__bracket">]</span>
            </a>
          </li>
        );
      })}
      <li>
        <button type="button" data-search-toggle class="nav-chip w-full justify-start" data-nav-sound aria-label="Search">
          <span class="nav-chip__bracket">[</span><span class="nav-chip__label">search</span><span class="nav-chip__bracket">]</span>
        </button>
      </li>
    </ul>
  </nav>

  <div class="mt-auto px-5 pt-4 pb-8 border-t border-text/20" id="mobile-nav-subscribe">
    <p class="mt-0 mb-3 text-sm text-text/75">Notes + reading list in your inbox.</p>
    <form action="https://buttondown.email/api/emails/embed-subscribe/guidefari" method="post" target="popupwindow" class="flex flex-col gap-2">
      <label for="bd-email-mobile" class="sr-only">Email address</label>
      <input type="email" name="email" id="bd-email-mobile" required placeholder="you@domain.com" autocomplete="email" class="w-full px-3 py-2 font-mono text-base bg-transparent border rounded-sm border-text/40 text-text placeholder:text-text/40 focus:outline-none focus:border-highlight focus:ring-1 focus:ring-highlight" />
      <button type="submit" class="px-4 py-2 font-mono text-sm font-semibold tracking-wide uppercase transition border rounded-sm border-highlight bg-highlight text-black hover:bg-transparent hover:text-highlight focus:outline-none focus:ring-2 focus:ring-highlight">Subscribe</button>
    </form>
  </div>
</div>

<style>
  .mobile-nav {
    transform: translateY(100%);
    opacity: 0;
  }
  .mobile-nav.is-open {
    transform: translateY(0);
    opacity: 1;
  }
  #mobile-nav-open[aria-expanded="true"] {
    display: none;
  }
  .nav-tree > details > summary::-webkit-details-marker {
    display: none;
  }
  .nav-tree > details > summary::marker {
    content: "";
  }
</style>

<script is:inline>
  (() => {
    const openBtn = document.getElementById("mobile-nav-open");
    const closeBtn = document.getElementById("mobile-nav-close");
    const overlay = document.getElementById("mobile-nav-overlay");
    const subscribe = document.getElementById("mobile-nav-subscribe");
    const emailInput = document.getElementById("bd-email-mobile");

    if (!openBtn || !closeBtn || !overlay) return;

    let savedScrollY = 0;

    function lockScroll() {
      savedScrollY = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.width = "100%";
    }

    function unlockScroll() {
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.width = "";
      window.scrollTo(0, savedScrollY);
    }

    function openNav() {
      overlay.classList.add("is-open");
      openBtn.setAttribute("aria-expanded", "true");
      lockScroll();
      closeBtn.focus();
    }

    function closeNav() {
      overlay.classList.remove("is-open");
      openBtn.setAttribute("aria-expanded", "false");
      unlockScroll();
      openBtn.focus();
    }

    openBtn.addEventListener("click", () => {
      if (openBtn.getAttribute("aria-expanded") === "true") closeNav();
      else openNav();
    });
    closeBtn.addEventListener("click", closeNav);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && openBtn.getAttribute("aria-expanded") === "true") closeNav();
    });

    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) closeNav();
    });

    overlay.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => closeNav());
    });

    if (emailInput && subscribe && window.visualViewport) {
      emailInput.addEventListener("focus", () => {
        requestAnimationFrame(() => {
          const subscribeRect = subscribe.getBoundingClientRect();
          const viewportHeight = window.visualViewport.height;
          if (subscribeRect.bottom > viewportHeight - 16) {
            subscribe.scrollIntoView({ block: "end", behavior: "smooth" });
          }
        });
      });
    }
  })();
</script>
