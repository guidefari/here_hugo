---
import { formatDate } from "../lib/content.mjs";
import { sectionLinks } from "../lib/site.mjs";

const { entry } = Astro.props;
const sectionHref = sectionLinks[entry.section] ?? `/${entry.section}/`;
const tagString = entry.tags.join(",");
---

<li class="list-none py-3" data-tags={tagString}>
  <div class="flex flex-col gap-1">
    <div class="flex items-start justify-between gap-2">
      <a href={entry.permalink} class="post-link font-bold leading-snug text-highlight hover:text-white transition-colors duration-150 no-underline">{entry.title}</a>
      <time class="text-xs font-mono text-text/40 shrink-0 mt-0.5">{formatDate(entry.date, { month: "short", year: "2-digit" })}{entry.draft && <span class="text-red-400"> DRAFT</span>}</time>
    </div>
    {entry.description && <span class="text-sm text-text/60 leading-snug">{entry.description}</span>}
    <a href={sectionHref} class="self-start text-xs font-mono text-accentText/60 tracking-widest hover:text-accentText transition-colors no-underline">{entry.section}</a>
  </div>
</li>
