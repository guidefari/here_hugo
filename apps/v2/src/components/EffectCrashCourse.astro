---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCanonicalUrl, getOgImage } from "../lib/content.mjs";

const { entry } = Astro.props;
const fm = entry.data ?? {};
const stations = Array.isArray(fm.stations) ? fm.stations : [];
const referenceRepos = Array.isArray(fm.reference_repos) ? fm.reference_repos : [];
const channels = Array.isArray(fm.channels) ? fm.channels : [];

const isExternal = (url) => typeof url === "string" && /^https?:\/\//.test(url);

const typeStyles = {
  video: "border-orange-400/30 text-orange-300",
  podcast: "border-pink-400/30 text-pink-300",
  article: "border-amber-400/30 text-amber-300",
  doc: "border-emerald-400/30 text-emerald-300",
  code: "border-cyan-400/30 text-cyan-300",
  course: "border-violet-400/30 text-violet-300",
  note: "border-zinc-400/30 text-zinc-300",
  link: "border-zinc-400/30 text-zinc-400",
};
const typeClass = (type) => typeStyles[type] ?? typeStyles.link;

const slugify = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");

const tabs = [
  ...stations.map((s) => ({ id: slugify(s.title), label: s.title, kind: "station" as const, data: s })),
  { id: "reference", label: "Reference", kind: "reference" as const, data: null },
];
---

<BaseLayout
  title={entry.title}
  description={entry.description}
  image={getOgImage(entry)}
  canonical={getCanonicalUrl(entry.permalink)}
  noindex={fm.noindex === true}
>
  <main class="flex flex-col mx-auto w-full max-w-3xl px-4 lg:px-6 py-12">

    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white m-0 mb-4 tracking-tight">
        {entry.title}
      </h1>
      {entry.description && (
        <p class="text-base text-accentText max-w-2xl leading-relaxed m-0">{entry.description}</p>
      )}
    </header>

    <div class="relative mb-8 -mx-4 lg:-mx-6">
      <nav
        class="flex gap-1 border-b border-white/10 overflow-x-auto no-scrollbar scroll-px-4 snap-x px-4 lg:px-6"
        role="tablist"
        id="effect-tabs"
      >
        {tabs.map((tab, i) => (
          <button
            role="tab"
            id={`tab-${tab.id}`}
            aria-controls={`panel-${tab.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            data-tab={tab.id}
            class:list={[
              "snap-start px-3 py-2 text-sm font-medium whitespace-nowrap transition-colors border-b-2 -mb-px cursor-pointer",
              i === 0
                ? "border-highlight text-highlight"
                : "border-transparent text-accentText/60 hover:text-accentText",
            ]}
          >
            {tab.label}
          </button>
        ))}
      </nav>
      <div
        class="pointer-events-none absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-bg to-transparent lg:hidden"
        aria-hidden="true"
      ></div>
    </div>

    {tabs.map((tab, i) => (
      <div
        role="tabpanel"
        id={`panel-${tab.id}`}
        aria-labelledby={`tab-${tab.id}`}
        data-panel={tab.id}
        class={i === 0 ? "" : "hidden"}
      >
        {tab.kind === "station" && (
          <div>
            {tab.data.blurb && (
              <p class="text-sm text-accentText/80 mb-6 max-w-2xl leading-relaxed">{tab.data.blurb}</p>
            )}
            <ul class="flex flex-col gap-2 list-none p-0 m-0">
              {tab.data.items.map((item) => (
                <li>
                  <a
                    href={item.url}
                    target={isExternal(item.url) ? "_blank" : undefined}
                    rel={isExternal(item.url) ? "noopener noreferrer" : undefined}
                    class="flex items-start gap-3 px-4 py-3 border border-white/5 hover:border-white/15 no-underline transition-colors group"
                  >
                    <div class="flex-1 min-w-0">
                      <h3 class="text-sm font-semibold text-white m-0 leading-snug group-hover:text-highlight transition-colors">
                        {item.title}
                      </h3>
                      {item.source && (
                        <p class="text-[11px] text-accentText/60 m-0 mt-0.5 font-mono truncate">
                          {item.source}
                        </p>
                      )}
                      {item.note && (
                        <p class="text-[12px] text-text/70 m-0 mt-1.5 leading-snug">{item.note}</p>
                      )}
                    </div>
                    <span
                      class={`shrink-0 font-mono text-[9px] tracking-wider px-1.5 py-0.5 border self-start mt-0.5 ${typeClass(item.type)}`}
                    >
                      {item.type}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {tab.kind === "reference" && (
          <div class="flex flex-col gap-10">
            {referenceRepos.length > 0 && (
              <div>
                <h2 class="text-lg font-bold text-white m-0 mb-1 tracking-tight">Repos worth reading</h2>
                <p class="text-sm text-accentText/80 mb-4 max-w-2xl leading-relaxed">
                  Real codebases using Effect in production.
                </p>
                <ul class="grid gap-2 list-none p-0 m-0 sm:grid-cols-2">
                  {referenceRepos.map((repo) => (
                    <li>
                      <a
                        href={repo.url}
                        target={isExternal(repo.url) ? "_blank" : undefined}
                        rel={isExternal(repo.url) ? "noopener noreferrer" : undefined}
                        class="block px-4 py-3 border border-white/5 hover:border-white/15 no-underline transition-colors group"
                      >
                        <h3 class="text-sm font-semibold text-white m-0 mb-1 font-mono group-hover:text-highlight transition-colors">
                          {repo.name}
                        </h3>
                        {repo.blurb && (
                          <p class="text-[12px] text-text/70 m-0 leading-relaxed">{repo.blurb}</p>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <div>
              <h2 class="text-lg font-bold text-white m-0 mb-3 tracking-tight">
                My Effect writing
              </h2>
              <a
                href="/tags/effect"
                class="inline-flex items-center gap-2 border border-highlight bg-highlight/10 px-4 py-2.5 text-sm font-mono font-semibold text-highlight no-underline transition hover:bg-highlight hover:text-black"
              >
                view all effect content
              </a>
            </div>

            {channels.length > 0 && (
              <div>
                <h2 class="text-lg font-bold text-white mb-1 tracking-tight">Channels</h2>
                <p class="text-sm text-accentText/80 mb-4 max-w-2xl leading-relaxed">
                  Where the team and community live.
                </p>
                <ul class="grid gap-2 list-none p-0 m-0 sm:grid-cols-2">
                  {channels.map((ch) => (
                    <li>
                      <a
                        href={ch.url}
                        target={isExternal(ch.url) ? "_blank" : undefined}
                        rel={isExternal(ch.url) ? "noopener noreferrer" : undefined}
                        class="block px-4 py-3 border border-white/5 hover:border-white/15 no-underline transition-colors group"
                      >
                        <h3 class="text-sm font-semibold text-white m-0 mb-1 font-mono group-hover:text-highlight transition-colors">
                          {ch.name}
                        </h3>
                        {ch.blurb && (
                          <p class="text-[12px] text-text/70 m-0 leading-relaxed">{ch.blurb}</p>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}
      </div>
    ))}
  </main>

  <script is:inline>
    (function () {
      var tabs = document.querySelectorAll("[role=tab]");
      var panels = document.querySelectorAll("[role=tabpanel]");

      function activate(id) {
        tabs.forEach(function (t) {
          var match = t.dataset.tab === id;
          t.setAttribute("aria-selected", match ? "true" : "false");
          t.classList.toggle("border-highlight", match);
          t.classList.toggle("text-highlight", match);
          t.classList.toggle("border-transparent", !match);
          t.classList.toggle("text-accentText/60", !match);
        });
        panels.forEach(function (p) {
          p.classList.toggle("hidden", p.dataset.panel !== id);
        });
      }

      tabs.forEach(function (t) {
        t.addEventListener("click", function () {
          var id = t.dataset.tab;
          activate(id);
          history.replaceState(null, "", "#" + id);
        });
      });

      var hash = location.hash.slice(1);
      if (hash && document.querySelector('[data-panel="' + hash + '"]')) {
        activate(hash);
      }

      window.addEventListener("hashchange", function () {
        var h = location.hash.slice(1);
        if (h && document.querySelector('[data-panel="' + h + '"]')) {
          activate(h);
        }
      });
    })();
  </script>
</BaseLayout>
