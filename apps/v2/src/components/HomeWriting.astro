---
import { getAllEntries } from "../lib/content.mjs";
import { homeWritingSections } from "../lib/site.mjs";
import PostListItemCompact from "./PostListItemCompact.astro";

const posts = getAllEntries().filter((entry) => homeWritingSections.includes(entry.section));
const featured = posts.filter((entry) => entry.frontmatter.featured);
const recent = posts.slice(0, 4);
---

{featured.length > 0 && (
  <div class="flex-1 min-w-0">
    <h2 class="text-xl font-bold tracking-tight text-white m-0 mb-3">Featured</h2>
    <ul class="flex flex-col divide-y divide-text/10 m-0 p-0">
      {featured.map((entry) => <PostListItemCompact entry={entry} />)}
    </ul>
  </div>
)}

<div class="flex-1 min-w-0">
  <h2 class="text-xl font-bold tracking-tight text-white m-0 mb-3">Recent</h2>
  <ul class="flex flex-col divide-y divide-text/10 m-0 p-0">
    {recent.map((entry) => <PostListItemCompact entry={entry} />)}
  </ul>
  <a href="/note/" class="inline-block mt-4 text-xs font-mono text-text/40 hover:text-highlight transition-colors duration-150 tracking-widest no-underline">all notes →</a>
</div>
