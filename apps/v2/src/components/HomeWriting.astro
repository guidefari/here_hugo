---
import { getAllEntries } from "../lib/content.mjs";
import { homeWritingSections, writingSections } from "../lib/site.mjs";
import PostListItemCompact from "./PostListItemCompact.astro";
import SectionMoreLink from "./SectionMoreLink.astro";

const entries = await getAllEntries();
const featured = entries.filter(
  (entry) => entry.data.featured && writingSections.includes(entry.section)
);
const featuredPermalinks = new Set(featured.map((entry) => entry.permalink));
const recent = entries
  .filter(
    (entry) =>
      homeWritingSections.includes(entry.section) &&
      !featuredPermalinks.has(entry.permalink)
  )
  .slice(0, 8);
---

<div class="grid grid-cols-1 xl:grid-cols-2 gap-10 min-w-0 items-start">
  {featured.length > 0 && (
    <section class="min-w-0">
      <h2 class="text-xl font-bold tracking-tight text-white m-0 mb-3">Featured</h2>
      <ul class="flex flex-col divide-y divide-text/10 m-0 p-0">
        {featured.map((entry) => (
          <PostListItemCompact entry={entry} dateOptions={{ month: "short", year: "numeric" }} />
        ))}
      </ul>
    </section>
  )}

  <section class="min-w-0">
    <h2 class="text-xl font-bold tracking-tight text-white m-0 mb-3">Recent</h2>
    <ul class="flex flex-col divide-y divide-text/10 m-0 p-0">
      {recent.map((entry) => <PostListItemCompact entry={entry} />)}
    </ul>
    <SectionMoreLink href="/note/" label="all notes" />
  </section>
</div>
