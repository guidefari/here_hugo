---
import BaseLayout from "../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { formatDate, getCanonicalUrl, getOgImage, tagSlugify } from "../lib/content.mjs";
import { getSeriesForEntry } from "../lib/series.mjs";
import SeriesNav from "./SeriesNav.astro";
import SeriesMobileNav from "./SeriesMobileNav.astro";
import SeriesPrevNext from "./SeriesPrevNext.astro";

const { entry } = Astro.props;
const { Content } = await render(entry._entry);

const series = entry.data?.full_width ? null : await getSeriesForEntry(entry);
---

<BaseLayout title={entry.title} description={entry.description} image={getOgImage(entry)} canonical={getCanonicalUrl(entry.permalink)} noindex={entry.data.noindex === true} hideFooter={entry.data.hide_footer === true} hasMermaid={entry.hasMermaid}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 pt-12 pb-8 lg:pt-8">
    {series && <SeriesMobileNav series={series} current={entry} />}
    <div class="mb-8">
      <h1 class="text-3xl lg:text-5xl text-white m-0">{entry.title}</h1>
      {entry.date && <time>Posted on {formatDate(entry.date, { month: "short", day: "numeric", year: "numeric" })}</time>}
      {entry.draft && <p class="draft-label">DRAFT</p>}
      <div class="post-tags" data-pagefind-meta="tags">
        {entry.tags.length > 0 && entry.section !== "page" && (
          <nav class="nav" aria-label="Tags">
            <ul class="single-tags">
              {entry.tags.map((tag) => (
                <li class="single-tag"><a href={`/tags/${tagSlugify(tag)}/`}>#{tag}</a></li>
              ))}
            </ul>
          </nav>
        )}
      </div>
    </div>
    {entry.data.tldr && <div class="tldr">{entry.data.tldr}</div>}
    <article class="prose lg:prose-xl prose-headings:max-w-none prose-pre:overflow-x-auto prose-pre:max-w-full [&_h2]:text-2xl [&_h2]:lg:text-4xl [&_h3]:text-xl [&_h3]:lg:text-3xl">
      <Content />
    </article>
    {series && <SeriesPrevNext series={series} current={entry} />}
  </main>

  {series && <SeriesNav slot="series-nav" series={series} current={entry} />}
</BaseLayout>