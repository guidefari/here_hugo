---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getCanonicalUrl, getOgImage, tagSlugify } from "../lib/content.mjs";

const { entry } = Astro.props;
const Content = entry.module.default;
---

<BaseLayout title={entry.title} description={entry.description} image={getOgImage(entry)} canonical={getCanonicalUrl(entry.permalink)} noindex={entry.frontmatter.noindex === true} hideFooter={entry.frontmatter.hide_footer === true} hasMermaid={entry.hasMermaid}>
  <main class="flex flex-col mx-auto w-full max-w-5xl px-4 lg:px-6 py-8">
    <div class="mb-8">
      <h1 class="text-5xl text-white m-0">{entry.title}</h1>
      {entry.date && <time>Posted on {formatDate(entry.date, { month: "short", day: "numeric", year: "numeric" })}</time>}
      {entry.draft && <p class="draft-label">DRAFT</p>}
      <div class="post-tags" data-pagefind-meta="tags">
        {entry.tags.length > 0 && entry.section !== "page" && (
          <nav class="nav" aria-label="Tags">
            <ul class="single-tags">
              {entry.tags.map((tag) => (
                <li class="single-tag"><a href={`/tags/${tagSlugify(tag)}/`}>#{tag}</a></li>
              ))}
            </ul>
          </nav>
        )}
      </div>
    </div>
    {entry.frontmatter.tldr && <div class="tldr">{entry.frontmatter.tldr}</div>}
    <article class="prose lg:prose-xl prose-headings:max-w-none [&_h2]:text-4xl [&_h3]:text-3xl">
      <Content />
    </article>
  </main>
</BaseLayout>
