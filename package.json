{
  "name": "here_hugo",
  "version": "1.0.0",
  "description": "- [ ] 404 page",
  "main": "index.js",
  "scripts": {
    "build": "bun tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/style.css && hugo --gc --minify && bun pagefind --site public",
    "watch": "bun tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/style.css --watch",
    "dev": "hugo --gc && bun pagefind --site public && concurrently \"hugo server --navigateToChanged --buildFuture\" \"bun run watch\"",
    "search:dev": "bun pagefind --site public",
    "dev:sst": "sst dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/txndai/here_hugo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/txndai/here_hugo/issues"
  },
  "homepage": "https://github.com/txndai/here_hugo#readme",
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "concurrently": "9.1.2",
    "pagefind": "1.4.0",
    "sst": "4.12.10",
    "tailwindcss": "4.2.4"
  },
  "dependencies": {}
}
