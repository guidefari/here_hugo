{
  "name": "here_hugo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "- [ ] 404 page",
  "main": "index.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=@here/v1 --filter=@here/v2",
    "build:v1": "bun --cwd apps/v1 run build",
    "build:v2": "bun --cwd apps/v2 run build",
    "watch": "bun --cwd apps/v1 run watch",
    "dev": "turbo run dev --filter=@here/v1 --filter=@here/v2",
    "dev:v1": "bun --cwd apps/v1 run dev",
    "dev:v2": "bun --cwd apps/v2 run dev",
    "search:dev": "bun --cwd apps/v1 run search:dev",
    "dev:sst": "sst dev",
    "urls:compare": "bun run build && bun scripts/compare-url-manifests.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/txndai/here_hugo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/txndai/here_hugo/issues"
  },
  "homepage": "https://github.com/txndai/here_hugo#readme",
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "concurrently": "9.1.2",
    "pagefind": "1.4.0",
    "sst": "4.12.10",
    "tailwindcss": "4.2.4",
    "turbo": "latest"
  },
  "dependencies": {}
}
